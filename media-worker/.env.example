# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=python-worker-consumer
KAFKA_TOPIC_JOB_CREATED=media.job.created
KAFKA_TOPIC_JOB_COMPLETED=media.job.completed

# Go API (status sync)
GO_API_BASE_URL=http://localhost:8080
GO_API_INTERNAL_TOKEN=internal-service-token-change-me

# External AI APIs (optional — if not set, local providers are used automatically)
# STT: Soniox or Groq → if both empty, falls back to local Whisper
# LLM: Gemini or Blackbox → if both empty, falls back to local Ollama
SONIOX_API_KEY=
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest
BLACKBOX_API_KEY=
BLACKBOX_API_BASE_URL=https://api.blackbox.ai/v1
BLACKBOX_MODEL=grok-code-fast

# S3 / MinIO (evidence pack storage)
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadminpass
S3_BUCKET_NAME=evidence-packs
S3_USE_SSL=false

# Cobalt API (self-hosted fallback downloader)
COBALT_API_URL=http://localhost:9090
COBALT_API_KEY=

# Local AI — Ollama (no API key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Local AI — Whisper (runs inside worker, no API key needed)
WHISPER_MODEL_SIZE=base

# yt-dlp cookies (Netscape format — export from browser with Get cookies.txt extension)
# Leave empty to skip cookie-based download
YTDLP_COOKIES_FILE=

# Processing
TMP_DIR=/tmp/mediawatch-jobs
MAX_VIDEO_DURATION_SECONDS=600
KEYFRAME_INTERVAL_SECONDS=3
KEYFRAME_MAX_WIDTH_PX=800
AUDIO_SAMPLE_RATE_HZ=16000
EVIDENCE_RISK_THRESHOLD=70

# Force local AI mode (only for testing — forces fallback to local Ollama + Whisper)
MOCK_MODE=false

# Gemini rate limiting
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_BASE_SECONDS=2
